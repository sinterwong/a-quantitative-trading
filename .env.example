# LLM API Keys (copy to .env and fill in your keys)
# DO NOT commit .env to git!

# MiniMax API (https://platform.minimaxi.com) — 推荐中文场景
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# DeepSeek API (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi (Moonshot) API (https://platform.moonshot.cn)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn

# Default provider: "minimax" | "deepseek" | "kimi"
LLM_PROVIDER=minimax

# Model selection per provider
DEEPSEEK_MODEL=deepseek-chat
KIMI_MODEL=moonshot-v1-8k

# Rate limiting (requests per minute)
LLM_RPM=60

# Cache TTL (seconds)
NEWS_CACHE_TTL=300
POLICY_CACHE_TTL=3600
