# .env.example — copy to .env and fill in values
# DO NOT commit .env to git!
#
# R3-4 续集: 跟代码里的 os.environ.get / os.getenv 调用对账过的完整列表。
# 留空或注释掉 = 该功能不启用（对应的 channel/feature 默认关闭）。
#
# 对账方法（任何新增环境变量必跑）:
#   grep -rhEo "os\.(environ\.get|getenv)\([\"']?[A-Z_][A-Z_0-9]+[\"']?" \
#       --include="*.py" core/ backend/ quant_app/ scripts/ services/ \
#     | sed -E "s/^os\.(environ\.get|getenv)\([\"']?//; s/[\"'].*//" \
#     | sort -u
# 输出和本文件 LHS 应当完全一致。


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  运行环境                                                            ║
# ╚══════════════════════════════════════════════════════════════════════╝

# 环境名（用于日志/可观测性区分）。常见值：dev / staging / prod。
TRADING_ENV=dev

# Flask 框架自身的 env 名。设 production 后 Flask 关闭调试。
FLASK_ENV=production


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  API 鉴权 / 限流                                                     ║
# ╚══════════════════════════════════════════════════════════════════════╝

# 调用方提交时携带 X-API-Key: <TRADING_API_KEY>。
# 留空 ⇒ 关闭鉴权（仅本机回环可访问的开发场景下可接受）。
TRADING_API_KEY=

# ⚠️  生产部署务必设 TRADING_API_REQUIRE_LOCALHOST=1。
# 默认 0：本机回环（127.0.0.1 / ::1）自动豁免鉴权与限流——
# 这是为了 Streamlit / 本机调度脚本零摩擦，但 systemd 守护进程
# 监听 0.0.0.0 时同机其它进程会绕过鉴权，务必关掉。
TRADING_API_REQUIRE_LOCALHOST=0

# 全局每分钟 per-IP 请求上限（0 = 关闭）。代码里实名 TRADING_RL_PER_MIN。
TRADING_RL_PER_MIN=120


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  数据 / 存储                                                         ║
# ╚══════════════════════════════════════════════════════════════════════╝

# state.db 自定义路径。未设 ⇒ 默认 data/state.db。
QUANT_STATE_DB=

# 设为非空 ⇒ 跳过 state.db 启动期 schema 迁移（CI / 只读副本场景）。
QUANT_STATE_DB_NO_MIGRATE=

# Risk state 持久化路径（HALT_NEW_BUYS 等开关）。
QUANT_RISK_STATE_PATH=

# 数据网关 disk cache 目录。未设 ⇒ data/cache/data_gateway/。
TRADING_DATA_GATEWAY_CACHE_DIR=


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  调度 / 报告推送                                                     ║
# ╚══════════════════════════════════════════════════════════════════════╝

# StrategyRunner 后台线程运行时长（秒），用于早盘后保持轮询。
RUNNER_RUNTIME=

# 是否在收盘 afternoon_report 时推送到飞书 / Telegram（1 启用 / 0 跳过）。
QUANT_AFTERNOON_REPORT_PUSH=1


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  LLM Providers                                                       ║
# ╚══════════════════════════════════════════════════════════════════════╝

# MiniMax (https://platform.minimaxi.com) — 推荐中文场景
# 注：MiniMax base URL 在代码里硬编码，无 env 覆盖。
MINIMAX_API_KEY=
MINIMAX_MODEL=abab6.5s-chat

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Kimi / Moonshot (https://platform.moonshot.cn)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn
KIMI_MODEL=moonshot-v1-8k

# Default provider: minimax | deepseek | kimi
LLM_PROVIDER=minimax

# 缓存 TTL（秒）
NEWS_CACHE_TTL=300
POLICY_CACHE_TTL=3600

# 当 LLM news review 失败时是否放行（1 = 放行 / 0 = 拦截）。
# 默认 1（fail-open，避免 LLM 故障误拦截下单）。
LLM_REVIEW_FAIL_OPEN=1


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  告警 / 推送通道                                                     ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── 飞书（Lark）─────────────────────────────────────────────────────
# Open APP 模式（推送给指定用户/群）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_OPEN_ID=
FEISHU_CHAT_ID=

# 自定义 Bot Webhook 模式（更简单，无需 OAuth）
# FEISHU_WEBHOOK 与 FEISHU_WEBHOOK_URL 同义，二选一即可。
FEISHU_WEBHOOK=
FEISHU_WEBHOOK_URL=

# ─── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 设 1 ⇒ Telegram 作为主推送通道（飞书降级为备份）。
TELEGRAM_AS_PRIMARY=0

# ─── 其它 Webhook 通道 ───────────────────────────────────────────────
DINGTALK_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=

# ─── 邮件告警 ────────────────────────────────────────────────────────
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_EMAIL_TO=
