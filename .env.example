# LLM API Keys (copy to .env and fill in your keys)
# DO NOT commit .env to git!

# MiniMax API (https://platform.minimaxi.com) — 推荐中文场景
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# DeepSeek API (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi (Moonshot) API (https://platform.moonshot.cn)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn

# Default provider: "minimax" | "deepseek" | "kimi"
LLM_PROVIDER=minimax

# Model selection per provider
DEEPSEEK_MODEL=deepseek-chat
KIMI_MODEL=moonshot-v1-8k

# Rate limiting (requests per minute)
LLM_RPM=60

# Cache TTL (seconds)
NEWS_CACHE_TTL=300
POLICY_CACHE_TTL=3600


# Feishu (Lark) Bot Credentials
# Get from: https://open.feishu.cn/app -> your app -> credentials
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_USER_OPEN_ID=your_feishu_user_open_id_here  # 飞书用户 open_id，用于接收推送消息


# ─── API 鉴权 ────────────────────────────────────────────────────────────
# 调用方提交时携带 X-API-Key: <TRADING_API_KEY>。
# 留空 ⇒ 关闭鉴权(仅本机回环可访问的开发场景下可接受)。
TRADING_API_KEY=

# ⚠️  生产部署务必设置 TRADING_API_REQUIRE_LOCALHOST=1。
# 默认 0,本机回环(127.0.0.1 / ::1)自动豁免鉴权与限流——
# 这是为了 Streamlit / 本机调度脚本零摩擦,但 systemd 守护进程
# 监听 0.0.0.0 时会被同一机器上的任意进程绕过鉴权,务必关掉。
TRADING_API_REQUIRE_LOCALHOST=0

# 全局每分钟 per-IP 请求上限(0=关闭)。
TRADING_API_RATE_LIMIT_PER_MIN=0
