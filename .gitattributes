# Force all Python files to use LF line endings on all platforms
# This prevents CRLF-related issues in CI (py_compile fails on Linux with CRLF)
*.py text=auto eol=lf

# Also normalize other text files
*.md text=auto eol=lf
*.yml text=auto eol=lf
*.yaml text=auto eol=lf
*.json text=auto eol=lf
*.txt text=auto eol=lf
*.bat text=auto eol=lf
*.sh text=auto eol=lf

# Keep binary files as-is
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.db binary
*.sqlite binary
*.db-journal binary
